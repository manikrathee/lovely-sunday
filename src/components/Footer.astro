---
import { readFileSync } from "node:fs";

const links = [
  { label: "Discover", href: "/lookbook" },
  { label: "Archive", href: "/daily-diary" },
  { label: "Contact", href: "/contact-lovely-sunday" },
  { label: "Instagram", href: "https://www.instagram.com/lovelysunday" },
];
const currentYear = new Date().getFullYear();
const footerLogoSvg = readFileSync(
  new URL("../../public/img/lovely-sunday-logo.svg", import.meta.url),
  "utf-8",
)
  .replace(/<\?xml[^?]*\?>\s*/g, "")
  .replace(/<!DOCTYPE[^>]*>\s*/g, "");
---

<footer class="site-foot">
  <div class="site-foot-logo" aria-hidden="true" set:html={footerLogoSvg} />

  <div class="site-foot-inner">
    <div class="site-foot-brand">
      <strong>Lovely Sunday</strong>
      <small>© {currentYear}</small>
    </div>

    <nav class="site-foot-nav" aria-label="Footer">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</footer>
