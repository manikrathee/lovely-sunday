---
import Layout from '../layouts/Layout.astro';
import ImageBlock from './ImageBlock.astro';
import InstagramFeed from './InstagramFeed.astro';

export interface Props {
  title?: string;
  description?: string;
  thumbnail?: string;
  articleClass?: string;
  includeExcerpt?: boolean;
  slug?: string;
  seo?: {
    pageType?: "article" | "website" | "collection" | "profile" | "contact" | "confirmation";
    publishedTime?: string;
    modifiedTime?: string;
  };
}

const {
  title,
  description,
  thumbnail,
  articleClass = 'post-content',
  includeExcerpt = false,
  slug,
  seo,
} = Astro.props;

const resolvedTitle = title || "";
---

<Layout
  title={resolvedTitle}
  description={description}
  seo={{
    pageType: seo?.pageType || "article",
    image: thumbnail,
    publishedTime: seo?.publishedTime,
    modifiedTime: seo?.modifiedTime,
  }}
>
  <article class={`${articleClass} ${thumbnail ? '' : 'no-image'}`.trim()}>
    {includeExcerpt && description && <p class="post-content-excerpt">{description}</p>}
    <ImageBlock src={thumbnail} alt={resolvedTitle} />

    <div class="post-content-body">
      <slot />
    </div>

    <slot name="after" />

    <InstagramFeed
      title={resolvedTitle}
      description={description}
      slug={slug}
      heading="Inspired by @_lovelysunday"
      limit={6}
    />
  </article>
</Layout>
