---
import LegacyHtmlPage from "../components/LegacyHtmlPage.astro";
import InstagramFeed from "../components/InstagramFeed.astro";
import { getLegacyPageBySourcePathname } from "../lib/legacy-pages";

const homePage = getLegacyPageBySourcePathname("/");
if (!homePage) {
  throw new Error("Missing legacy homepage source for '/'");
}
---

<LegacyHtmlPage rawHtml={homePage.rawHtml} />
<InstagramFeed
  title="Lovely Sunday"
  description="Homepage highlights"
  slug="home"
  heading="Latest from @_lovelysunday"
  limit={9}
/>
