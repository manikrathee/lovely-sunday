---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Thank You"
  description="Thanks for contacting Lovely Sunday. Your message has been received."
  seo={{ pageType: "confirmation" }}
>
  <article class="post-content page-template no-image">
    <div class="post-content-body">
      <section class="thank-you">
        <h1>Thank you!</h1>
        <p>Your submission has been received.</p>
        <p><a href="/">Back to Home</a></p>
      </section>
    </div>
  </article>
</Layout>

<style>
  .thank-you {
    display: grid;
    gap: 0.75rem;
    place-items: center;
    text-align: center;
    padding: 2rem 0;
  }
</style>
