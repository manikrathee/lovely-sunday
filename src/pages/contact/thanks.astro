---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Thank You"
  description="Thanks for contacting Lovely Sunday. Your message has been received."
  seo={{ pageType: "confirmation" }}
>
  <article class="post-content page-template no-image">
    <div class="post-content-body">
      <div class="thank-you" style="display: flex; flex-direction: column; align-items: center; text-align: center;">
         <h1>Thank you!</h1>
         <p>Your submission has been received.</p>
         <p><a href="/">Back to Home</a></p>
      </div>
    </div>
  </article>
</Layout>
